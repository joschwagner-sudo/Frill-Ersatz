// Prisma Schema — Frill-Ersatz MVP
// SQLite locally, Postgres-ready via DATABASE_URL swap

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ──────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  lastLoginAt DateTime?

  createdRequests       FeatureRequest[]       @relation("CreatedRequests")
  votes                 Vote[]
  comments              Comment[]
  announcements         Announcement[]
  emailLogs             AnnouncementEmailLog[]
  announcementReactions AnnouncementReaction[]
}

// ─── Auth Code (Magic Link 6-digit) ───────────────────
model AuthCode {
  id        String    @id @default(cuid())
  email     String
  code      String    // bcrypt-hashed
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// ─── Feature Request ──────────────────────────────────
model FeatureRequest {
  id             String   @id @default(cuid())
  number         Int      @default(autoincrement())
  title          String   // max 80 chars (validated in app)
  description    String   // markdown
  type           String   @default("FEATURE") // FEATURE | BUG
  status         String?  // UNDER_REVIEW | PLANNED | IN_PROGRESS | DONE | NOT_PLANNED
  approvalStatus String   @default("NEEDS_APPROVAL") // NEEDS_APPROVAL | APPROVED | REJECTED
  isPinned       Boolean  @default(false)
  isPrivate      Boolean  @default(false)
  isShortlisted  Boolean  @default(false)
  tags           String   @default("") // comma-separated for SQLite simplicity
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String
  createdBy   User @relation("CreatedRequests", fields: [createdById], references: [id])

  votes       Vote[]
  comments    Comment[]
  roadmapItem RoadmapItem?
  topics      IdeaTopics[]

  @@index([createdById])
  @@index([type])
  @@index([status])
  @@index([approvalStatus])
  @@index([number])
}

// ─── Vote ─────────────────────────────────────────────
model Vote {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())

  userId           String
  user             User @relation(fields: [userId], references: [id])

  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@unique([userId, featureRequestId])
  @@index([featureRequestId])
}

// ─── Roadmap Item ─────────────────────────────────────
model RoadmapItem {
  id               String   @id @default(cuid())
  quarter          String   // e.g. "2026-Q1"
  priority         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  featureRequestId String   @unique
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([quarter])
}

// ─── Announcement ─────────────────────────────────────
model Announcement {
  id          String    @id @default(cuid())
  title       String    // max 100 chars (validated in app)
  body        String    // markdown
  publishedAt DateTime?
  pinned      Boolean   @default(false)
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  categoryId  String?
  category    AnnouncementCategory? @relation("AnnouncementCategory", fields: [categoryId], references: [id])

  emailLogs   AnnouncementEmailLog[]
  reactions   AnnouncementReaction[]

  @@index([publishedAt])
  @@index([categoryId])
}

// ─── Announcement Email Log ───────────────────────────
model AnnouncementEmailLog {
  id             String   @id @default(cuid())
  status         String   @default("QUEUED") // QUEUED | SENT | FAILED
  error          String?
  createdAt      DateTime @default(now())

  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  userId         String
  user           User @relation(fields: [userId], references: [id])

  @@index([announcementId])
}

// ─── Announcement Category ────────────────────────────
model AnnouncementCategory {
  id            String         @id @default(cuid())
  name          String         @unique
  color         String         // hex color
  emoji         String         @default("")
  createdAt     DateTime       @default(now())
  announcements Announcement[] @relation("AnnouncementCategory")
}

// ─── Announcement Reaction ────────────────────────────
model AnnouncementReaction {
  id             String       @id @default(cuid())
  emoji          String       // 🔥 ❤️ 👍
  createdAt      DateTime     @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId, emoji])
  @@index([announcementId])
  @@index([userId])
}

// ─── Report to Intercom ───────────────────────────────
model ReportToIntercom {
  id                     String   @id @default(cuid())
  type                   String   // BUG | FEATURE
  title                  String
  description            String
  userEmail              String
  pageUrl                String?
  intercomDeliveryStatus String   @default("PENDING") // PENDING | SENT | FAILED
  intercomResponse       String?
  createdAt              DateTime @default(now())
}

// ─── Comment ──────────────────────────────────────────
model Comment {
  id               String         @id @default(cuid())
  body             String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  userId           String
  user             User           @relation(fields: [userId], references: [id])

  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@index([userId])
}

// ─── Topic ────────────────────────────────────────────
model Topic {
  id        String   @id @default(cuid())
  name      String
  emoji     String   @default("")
  order     Int      @default(0)
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ideas     IdeaTopics[]
}

// ─── Idea Topics (Many-to-Many) ───────────────────────
model IdeaTopics {
  id               String         @id @default(cuid())
  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  topicId          String
  topic            Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, topicId])
  @@index([featureRequestId])
  @@index([topicId])
}
