generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  isAdmin               Boolean                @default(false)
  createdAt             DateTime               @default(now())
  lastLoginAt           DateTime?
  emailNotifications    Boolean                @default(true)
  announcements         Announcement[]
  emailLogs             AnnouncementEmailLog[]
  announcementReactions AnnouncementReaction[]
  comments              Comment[]
  commentReactions      CommentReaction[]
  sentEmails            EmailBroadcast[]       @relation("SentEmails")
  createdRequests       FeatureRequest[]       @relation("CreatedRequests")
  notifications         Notification[]
  votes                 Vote[]
}

model AuthCode {
  id        String    @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model FeatureRequest {
  id              String           @id @default(cuid())
  title           String
  description     String
  type            String           @default("FEATURE")
  status          String?
  archived        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String
  approvalStatus  String           @default("NEEDS_APPROVAL")
  isPinned        Boolean          @default(false)
  isPrivate       Boolean          @default(false)
  isShortlisted   Boolean          @default(false)
  number          Int              @default(autoincrement())
  mergedIntoId    String?
  isAnonymous     Boolean          @default(true)
  platform        String           @default("BOTH")
  rejectionReason String?
  comments        Comment[]
  createdBy       User             @relation("CreatedRequests", fields: [createdById], references: [id])
  mergedInto      FeatureRequest?  @relation("MergedIdeas", fields: [mergedIntoId], references: [id])
  mergedFrom      FeatureRequest[] @relation("MergedIdeas")
  topics          IdeaTopics[]
  Notification    Notification[]
  roadmapItem     RoadmapItem?
  votes           Vote[]

  @@index([createdById])
  @@index([type])
  @@index([status])
  @@index([approvalStatus])
  @@index([number])
  @@index([mergedIntoId])
}

model Vote {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  userId           String
  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id])

  @@unique([userId, featureRequestId])
  @@index([featureRequestId])
}

model RoadmapItem {
  id               String         @id @default(cuid())
  quarter          String?
  priority         Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  featureRequestId String         @unique
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([quarter])
}

model Announcement {
  id          String                 @id @default(cuid())
  title       String
  body        String
  publishedAt DateTime?
  pinned      Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  createdById String
  categoryId  String?
  category    AnnouncementCategory?  @relation("AnnouncementCategory", fields: [categoryId], references: [id])
  createdBy   User                   @relation(fields: [createdById], references: [id])
  emailLogs   AnnouncementEmailLog[]
  reactions   AnnouncementReaction[]

  @@index([publishedAt])
  @@index([categoryId])
}

model AnnouncementEmailLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()"))
  status         String       @default("QUEUED")
  error          String?
  createdAt      DateTime     @default(now())
  announcementId String
  userId         String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([announcementId])
}

model AnnouncementCategory {
  id            String         @id @default(cuid())
  name          String         @unique
  color         String
  emoji         String         @default("")
  createdAt     DateTime       @default(now())
  announcements Announcement[] @relation("AnnouncementCategory")
}

model AnnouncementReaction {
  id             String       @id @default(cuid())
  emoji          String
  createdAt      DateTime     @default(now())
  userId         String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@unique([userId, announcementId, emoji])
  @@index([announcementId])
  @@index([userId])
}

model ReportToIntercom {
  id               String   @id(map: "ReportToSupport_pkey") @default(cuid())
  type             String
  title            String
  description      String
  category         String?
  userEmail        String?
  copilotUsername  String?
  pageUrl          String?
  deliveryStatus   String   @default("PENDING")
  deliveryResponse String?
  createdAt        DateTime @default(now())
}

model EmailBroadcast {
  id              String    @id @default(cuid())
  subject         String
  body            String
  bodyHtml        String
  recipientType   String
  recipientFilter String?
  recipientCount  Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  status          String    @default("DRAFT")
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sentById        String
  sentBy          User      @relation("SentEmails", fields: [sentById], references: [id])

  @@index([status])
  @@index([createdAt])
}

model Comment {
  id               String            @id @default(cuid())
  body             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userId           String
  featureRequestId String
  isOfficial       Boolean           @default(false)
  parentId         String?
  featureRequest   FeatureRequest    @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  parent           Comment?          @relation("CommentReplies", fields: [parentId], references: [id])
  replies          Comment[]         @relation("CommentReplies")
  user             User              @relation(fields: [userId], references: [id])
  reactions        CommentReaction[]

  @@index([featureRequestId])
  @@index([userId])
  @@index([parentId])
}

model CommentReaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())
  userId    String
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, commentId, emoji])
  @@index([commentId])
}

model Topic {
  id        String       @id @default(cuid())
  name      String
  emoji     String       @default("")
  order     Int          @default(0)
  isPrivate Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  ideas     IdeaTopics[]
}

model IdeaTopics {
  id               String         @id @default(cuid())
  featureRequestId String
  topicId          String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  topic            Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, topicId])
  @@index([featureRequestId])
  @@index([topicId])
}

model Notification {
  id             String          @id @default(cuid())
  type           String
  message        String
  read           Boolean         @default(false)
  ideaId         String?
  createdAt      DateTime        @default(now())
  userId         String
  FeatureRequest FeatureRequest? @relation(fields: [ideaId], references: [id])
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
