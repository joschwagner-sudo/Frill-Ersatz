// Prisma Schema — Frill-Ersatz MVP
// SQLite locally, Postgres-ready via DATABASE_URL swap

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ──────────────────────────────────────────────
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  isAdmin            Boolean  @default(false)
  emailNotifications Boolean  @default(true)
  createdAt          DateTime @default(now())
  lastLoginAt        DateTime?

  createdRequests       FeatureRequest[]       @relation("CreatedRequests")
  votes                 Vote[]
  comments              Comment[]
  announcements         Announcement[]
  emailLogs             AnnouncementEmailLog[]
  announcementReactions AnnouncementReaction[]
  notifications         Notification[]
  commentReactions      CommentReaction[]
  sentEmails            EmailBroadcast[]   @relation("SentEmails")
}

// ─── Auth Code (Magic Link 6-digit) ───────────────────
model AuthCode {
  id        String    @id @default(cuid())
  email     String
  code      String    // bcrypt-hashed
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// ─── Feature Request ──────────────────────────────────
model FeatureRequest {
  id             String   @id @default(cuid())
  number         Int      @default(autoincrement())
  title          String   // max 80 chars (validated in app)
  description    String   // markdown
  type           String   @default("FEATURE") // FEATURE | BUG
  status         String?  // UNDER_REVIEW | PLANNED | IN_PROGRESS | DONE | NOT_PLANNED | MERGED
  approvalStatus String   @default("NEEDS_APPROVAL") // NEEDS_APPROVAL | APPROVED | REJECTED
  isPinned       Boolean  @default(false)
  isPrivate      Boolean  @default(false)
  isShortlisted  Boolean  @default(false)
  tags           String   @default("") // comma-separated for SQLite simplicity
  isAnonymous    Boolean  @default(true)
  archived       Boolean  @default(false)
  mergedIntoId   String?  // If merged, points to target idea
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String
  createdBy   User @relation("CreatedRequests", fields: [createdById], references: [id])

  votes       Vote[]
  comments    Comment[]
  roadmapItem RoadmapItem?
  topics      IdeaTopics[]
  mergedInto  FeatureRequest?  @relation("MergedIdeas", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom  FeatureRequest[] @relation("MergedIdeas")

  @@index([createdById])
  @@index([type])
  @@index([status])
  @@index([approvalStatus])
  @@index([number])
  @@index([mergedIntoId])
}

// ─── Vote ─────────────────────────────────────────────
model Vote {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())

  userId           String
  user             User @relation(fields: [userId], references: [id])

  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@unique([userId, featureRequestId])
  @@index([featureRequestId])
}

// ─── Roadmap Item ─────────────────────────────────────
model RoadmapItem {
  id               String   @id @default(cuid())
  quarter          String   // e.g. "2026-Q1"
  priority         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  featureRequestId String   @unique
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([quarter])
}

// ─── Announcement ─────────────────────────────────────
model Announcement {
  id          String    @id @default(cuid())
  title       String    // max 100 chars (validated in app)
  body        String    // markdown
  publishedAt DateTime?
  pinned      Boolean   @default(false)
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  categoryId  String?
  category    AnnouncementCategory? @relation("AnnouncementCategory", fields: [categoryId], references: [id])

  emailLogs   AnnouncementEmailLog[]
  reactions   AnnouncementReaction[]

  @@index([publishedAt])
  @@index([categoryId])
}

// ─── Announcement Email Log ───────────────────────────
model AnnouncementEmailLog {
  id             String   @id @default(cuid())
  status         String   @default("QUEUED") // QUEUED | SENT | FAILED
  error          String?
  createdAt      DateTime @default(now())

  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  userId         String
  user           User @relation(fields: [userId], references: [id])

  @@index([announcementId])
}

// ─── Announcement Category ────────────────────────────
model AnnouncementCategory {
  id            String         @id @default(cuid())
  name          String         @unique
  color         String         // hex color
  emoji         String         @default("")
  createdAt     DateTime       @default(now())
  announcements Announcement[] @relation("AnnouncementCategory")
}

// ─── Announcement Reaction ────────────────────────────
model AnnouncementReaction {
  id             String       @id @default(cuid())
  emoji          String       // 🔥 ❤️ 👍
  createdAt      DateTime     @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId, emoji])
  @@index([announcementId])
  @@index([userId])
}

// ─── Report to Intercom ───────────────────────────────
model ReportToIntercom {
  id                     String   @id @default(cuid())
  type                   String   // BUG | FEATURE
  title                  String
  description            String
  userEmail              String
  pageUrl                String?
  intercomDeliveryStatus String   @default("PENDING") // PENDING | SENT | FAILED
  intercomResponse       String?
  createdAt              DateTime @default(now())
}

// ─── Admin Email Broadcast ────────────────────────────
model EmailBroadcast {
  id             String   @id @default(cuid())
  subject        String
  body           String   // markdown
  bodyHtml       String   // rendered HTML
  recipientType  String   // ALL | IDEA_VOTERS | ADMINS | CUSTOM
  recipientFilter String? // e.g. idea ID for IDEA_VOTERS
  recipientCount Int      @default(0)
  sentCount      Int      @default(0)
  failedCount    Int      @default(0)
  status         String   @default("DRAFT") // DRAFT | SENDING | SENT | FAILED
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sentById       String
  sentBy         User     @relation("SentEmails", fields: [sentById], references: [id])

  @@index([status])
  @@index([createdAt])
}

// ─── Comment ──────────────────────────────────────────
model Comment {
  id               String         @id @default(cuid())
  body             String
  isOfficial       Boolean        @default(false)
  parentId         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  userId           String
  user             User           @relation(fields: [userId], references: [id])

  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  parent           Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies          Comment[]      @relation("CommentReplies")
  reactions        CommentReaction[]

  @@index([featureRequestId])
  @@index([userId])
  @@index([parentId])
}

// ─── Comment Reaction ─────────────────────────────────
model CommentReaction {
  id        String   @id @default(cuid())
  emoji     String   // 👍 ❤️ 😂 🎉 🤔 👀
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId, emoji])
  @@index([commentId])
}

// ─── Topic ────────────────────────────────────────────
model Topic {
  id        String   @id @default(cuid())
  name      String
  emoji     String   @default("")
  order     Int      @default(0)
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ideas     IdeaTopics[]
}

// ─── Idea Topics (Many-to-Many) ───────────────────────
model IdeaTopics {
  id               String         @id @default(cuid())
  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  topicId          String
  topic            Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, topicId])
  @@index([featureRequestId])
  @@index([topicId])
}

// ─── Notification ─────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  type      String   // IDEA_APPROVED | STATUS_CHANGED | NEW_COMMENT
  message   String
  read      Boolean  @default(false)
  ideaId    String?
  createdAt DateTime @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
